# Copy to .env for local `netlify dev` use. In production, set these in
# Netlify's Site settings -> Environment variables instead.

# api-sports.io / API-Football key (used for Man City, Barcelona, Flamengo)
API_FOOTBALL_KEY=

# TheSportsDB key (used for Nashville SC, San Jose Earthquakes)
# Leave blank to fall back to the public "3" test key (limited/free tier).
SPORTSDB_KEY=
